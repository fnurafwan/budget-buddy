{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "budget-buddy",
  "compatibility_date": "2026-02-28",
  "observability": {
    "enabled": true
  },
  "main": "worker.js",
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}